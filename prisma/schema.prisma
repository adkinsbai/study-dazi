generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String         @id @default(uuid())
  username                  String         @unique
  email                     String         @unique
  passwordHash              String         @map("password_hash")
  emailVerified             Boolean        @default(false) @map("email_verified")
  avatarUrl                 String?        @map("avatar_url")
  bio                       String?        @map("bio")
  deepseekApiKey            String?        @map("deepseek_api_key") // deprecated: 迁移到 UserApiKey 表
  apiKeys                   UserApiKey[]
  verificationCode          String?        @map("verification_code")
  verificationCodeExpiresAt DateTime?      @map("verification_code_expires_at")
  verificationAttempts      Int            @default(0) @map("verification_attempts")
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")
  refreshTokens             RefreshToken[]
  learningPaths             LearningPath[]
  nodeProgress              UserNodeProgress[]
  checkIns                  CheckIn[]
  posts                     Post[]
  sentRequests              Friendship[] @relation("from")
  receivedRequests          Friendship[] @relation("to")
  resources                 Resource[]
  likes                     Like[]
  sentBuddies               StudyBuddy[] @relation("buddyFrom")
  receivedBuddies           StudyBuddy[] @relation("buddyTo")
  createdGroups             BuddyGroup[]  @relation("groupCreator")
  groupMemberships          BuddyGroupMember[]
  comments                  NodeComment[]
  sentMessages              Message[]     @relation("msgFrom")
  receivedMessages          Message[]     @relation("msgTo")
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]

  @@map("users")
}

model LearningPath {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  domain      String
  treeData    Json     @map("tree_data")
  userProfile String?  @map("user_profile") // 用户学习画像（Markdown格式）
  isPublic    Boolean  @default(false) @map("is_public")
  isTemplate  Boolean  @default(false) @map("is_template")
  forkCount   Int      @default(0) @map("fork_count")
  forkedFrom  String?  @map("forked_from")
  visibility  String   @default("public") @map("visibility")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  forkedPath   LearningPath?      @relation("ForkSource", fields: [forkedFrom], references: [id], onDelete: SetNull)
  forks        LearningPath[]     @relation("ForkSource")
  nodeProgress UserNodeProgress[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([isTemplate, domain])
  @@map("learning_paths")
}

model UserNodeProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  pathId      String    @map("path_id")
  nodeId      String    @map("node_id")
  status      String    @default("locked") // locked | unlocked | in_progress | completed
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  notes       String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path        LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId, nodeId])
  @@index([userId, pathId])
  @@map("user_node_progress")
}

model CheckIn {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  pathId      String?  @map("path_id")
  nodeId      String?  @map("node_id")
  checkInDate DateTime @map("check_in_date") @db.Date
  durationMin Int?     @map("duration_min")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkInDate])
  @@index([userId, checkInDate])
  @@map("check_ins")
}

model Post {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  content      String
  images       Json     @default("[]")
  markdown     String?  @map("markdown")
  markdownHtml String?  @map("markdown_html")
  visibility   String   @default("public") @map("visibility") // public | friends | buddies
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("posts")
}

model Friendship {
  id         String    @id @default(uuid())
  fromUserId String    @map("from_user_id")
  toUserId   String    @map("to_user_id")
  status     String    @default("pending") // pending | accepted | rejected
  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")
  fromUser   User      @relation("from", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User      @relation("to", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
  @@map("friendships")
}

model Resource {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  url         String?
  fileUrl     String?  @map("file_url")
  fileName    String?  @map("file_name")
  domain      String
  description String?
  notes       String?
  visibility  String   @default("public") @map("visibility") // public | friends | buddies
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([userId, createdAt(sort: Desc)])
  @@map("resources")
}

model StudyBuddy {
  id           String    @id @default(uuid())
  fromUserId   String    @map("from_user_id")
  toUserId     String    @map("to_user_id")
  domain       String
  sharedPathId String?   @map("shared_path_id")
  status       String    @default("pending") // pending | active | ended
  createdAt    DateTime  @default(now()) @map("created_at")
  activeAt     DateTime? @map("active_at")
  fromUser     User      @relation("buddyFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User      @relation("buddyTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId, domain])
  @@map("study_buddies")
}

model BuddyGroup {
  id           String             @id @default(uuid())
  name         String
  domain       String
  sharedPathId String?            @map("shared_path_id")
  createdBy    String             @map("created_by")
  createdAt    DateTime           @default(now()) @map("created_at")
  creator      User               @relation("groupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members      BuddyGroupMember[]

  @@map("buddy_groups")
}

model BuddyGroupMember {
  id       String     @id @default(uuid())
  groupId  String     @map("group_id")
  userId   String     @map("user_id")
  role     String     @default("member")
  joinedAt DateTime   @default(now()) @map("joined_at")
  group    BuddyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("buddy_group_members")
}

model Message {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  fromUser   User     @relation("msgFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("msgTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId, toUserId, createdAt(sort: Desc)])
  @@index([toUserId, read])
  @@map("messages")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   // friend_request | buddy_invite | like | comment | message
  referenceId String?  @map("reference_id")
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model NodeComment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  pathId    String   @map("path_id")
  nodeId    String   @map("node_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pathId, nodeId, createdAt(sort: Desc)])
  @@map("node_comments")
}

model Like {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  postId     String?  @map("post_id")
  resourceId String?  @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, resourceId])
  @@index([userId])
  @@map("likes")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@map("refresh_tokens")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model UserApiKey {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String   // deepseek | mimo | openai | openai-relay
  apiKey    String   @map("api_key")
  baseUrl   String?  @map("base_url") // 中转站自定义地址
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_api_keys")
}

/// 结构化资源库 —— YouTube/B站/Coursera 等平台的课程索引
model ResourceIndex {
  id          String   @id @default(uuid())
  platform    String   // youtube | bilibili | coursera | mit_ocw | other
  externalId  String?  @map("external_id") // YouTube videoId / B站 bvid
  title       String
  url         String
  instructor  String?
  thumbnail   String?
  duration    Int?     // 总时长（秒）
  language    String?  // zh / en
  difficulty  String?  // beginner | intermediate | advanced
  domain      String   // 所属领域（如：前端开发、模拟IC设计）
  tags        Json     @default("[]") // 知识点标签 ["CMOS","偏置电路"]
  rating      Float?   // 综合评分 0-5
  viewCount   Int?     @default(0) @map("view_count")
  isFree      Boolean  @default(true) @map("is_free")
  lastChecked DateTime @map("last_checked")
  createdAt   DateTime @default(now()) @map("created_at")

  nodeLinks NodeResource[]

  @@index([domain, difficulty])
  @@index([platform, domain])
  @@index([domain])
  @@map("resource_index")
}

/// 节点-资源关联（多对多）
model NodeResource {
  id         String @id @default(uuid())
  pathId     String @map("path_id")
  nodeId     String @map("node_id")
  resourceId String @map("resource_id")
  relevance  Float  @default(0) // AI 计算的相关度 0-1
  addedBy    String @default("ai") @map("added_by") // ai | user

  resource ResourceIndex @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([nodeId, resourceId])
  @@index([pathId, nodeId])
  @@map("node_resources")
}

// ============================================================
// Enums
// ============================================================

enum QuestionType {
  single_choice
  multi_choice
  fill_blank
  short_answer
  coding
  true_false
}

enum TestType {
  test
  homework
  exam
  review
}

enum TestSessionStatus {
  in_progress
  completed
  abandoned
}

enum ProjectDifficulty {
  beginner
  intermediate
  advanced
}

enum SubmissionStatus {
  submitted
  reviewed
  rejected
}

enum ProblemDifficulty {
  easy
  medium
  hard
}

enum AttemptStatus {
  pending
  accepted
  wrong_answer
  time_limit
  runtime_error
  compilation_error
}

enum ProblemSource {
  leetcode
  codeforces
  luogu
  other
}

enum CompanyTestSource {
  nowcoder
  leetcode
  saiding
  other
}

enum InterviewRound {
  general
  technical
  behavioral
  system_design
}

enum InterviewStatus {
  in_progress
  completed
}

// ============================================================
// Question & Test Models
// ============================================================

model QuestionBank {
  id          String       @id @default(uuid())
  pathId      String?      @map("path_id")
  nodeId      String?      @map("node_id")
  domain      String
  type        QuestionType
  difficulty  Int          // 1-5
  title       String
  content     Json
  answer      String
  explanation String?
  tags        Json         @default("[]")
  source      String       @default("ai")
  aiGenerated Boolean      @default(true) @map("ai_generated")
  confidence  Float?
  createdAt   DateTime     @default(now()) @map("created_at")

  answers          UserAnswer[]
  sessionQuestions TestSessionQuestion[]

  @@index([domain, difficulty])
  @@index([nodeId])
  @@map("question_bank")
}

model UserAnswer {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  questionId String        @map("question_id")
  answer     String
  isCorrect  Boolean?      @map("is_correct")
  score      Int?
  feedback   String?
  timeSpent  Int?          @map("time_spent")
  createdAt  DateTime      @default(now()) @map("created_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("user_answers")
}

model TestSession {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  pathId         String?           @map("path_id")
  nodeId         String?           @map("node_id")
  type           TestType
  title          String
  totalQuestions  Int              @map("total_questions")
  correctCount   Int              @default(0) @map("correct_count")
  score          Int?
  duration       Int?
  status         TestSessionStatus @default(in_progress)
  startedAt      DateTime          @default(now()) @map("started_at")
  completedAt    DateTime?         @map("completed_at")
  createdAt      DateTime          @default(now()) @map("created_at")

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  path      LearningPath?         @relation(fields: [pathId], references: [id], onDelete: SetNull)
  questions TestSessionQuestion[]

  @@index([userId, type, createdAt(sort: Desc)])
  @@map("test_sessions")
}

model TestSessionQuestion {
  id           String  @id @default(uuid())
  sessionId    String  @map("session_id")
  questionId   String  @map("question_id")
  userAnswerId String? @map("user_answer_id")
  order        Int
  isCorrect    Boolean? @map("is_correct")

  session  TestSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("test_session_questions")
}

// ============================================================
// Project Models
// ============================================================

model ProjectTemplate {
  id                String            @id @default(uuid())
  pathId            String?           @map("path_id")
  nodeId            String?           @map("node_id")
  domain            String
  title             String
  description       String
  requirements      Json
  difficulty        ProjectDifficulty
  estimatedHours    Int?              @map("estimated_hours")
  techStack         Json              @default("[]") @map("tech_stack")
  hints             Json              @default("[]")
  evaluationCriteria Json             @default("[]") @map("evaluation_criteria")
  resources         Json              @default("[]")
  aiGenerated       Boolean           @default(true) @map("ai_generated")
  createdAt         DateTime          @default(now()) @map("created_at")

  submissions ProjectSubmission[]

  @@index([domain, difficulty])
  @@map("project_templates")
}

model ProjectSubmission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  projectId    String           @map("project_id")
  content      String
  repoUrl      String?          @map("repo_url")
  demoUrl      String?          @map("demo_url")
  score        Int?
  feedback     String?
  aiEvaluation Json?            @map("ai_evaluation")
  status       SubmissionStatus @default(submitted)
  submittedAt  DateTime         @default(now()) @map("submitted_at")
  reviewedAt   DateTime?        @map("reviewed_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project ProjectTemplate @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt(sort: Desc)])
  @@map("project_submissions")
}

// ============================================================
// Coding Problem Models
// ============================================================

model CodingProblem {
  id             String           @id @default(uuid())
  externalSource ProblemSource?   @map("external_source")
  externalId     String?          @map("external_id")
  title          String
  description    String
  difficulty     ProblemDifficulty
  tags           Json             @default("[]")
  examples       Json             @default("[]")
  constraints    String?
  solution       String?
  hints          Json             @default("[]")
  acceptanceRate Float?           @map("acceptance_rate")
  isPremium      Boolean          @default(false) @map("is_premium")
  createdAt      DateTime         @default(now()) @map("created_at")

  attempts     UserCodingAttempt[]
  companyTests CompanyTestProblem[]

  @@index([difficulty])
  @@index([externalSource])
  @@map("coding_problems")
}

model UserCodingAttempt {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  problemId       String       @map("problem_id")
  language        String
  code            String
  status          AttemptStatus @default(pending)
  runtime         Int?
  memory          Int?
  testCasesPassed Int?         @map("test_cases_passed")
  totalTestCases  Int?         @map("total_test_cases")
  submittedAt     DateTime     @default(now()) @map("submitted_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt(sort: Desc)])
  @@map("user_coding_attempts")
}

// ============================================================
// Company Test Models
// ============================================================

model CompanyTest {
  id            String            @id @default(uuid())
  company       String
  year          Int
  position      String
  source        CompanyTestSource
  url           String?
  difficulty    Int?
  questionCount Int               @default(0) @map("question_count")
  tags          Json              @default("[]")
  createdAt     DateTime          @default(now()) @map("created_at")

  problems CompanyTestProblem[]

  @@index([company, year])
  @@map("company_tests")
}

model CompanyTestProblem {
  id         String  @id @default(uuid())
  testId     String  @map("test_id")
  problemId  String? @map("problem_id")
  questionId String? @map("question_id")
  order      Int     @default(0)

  test    CompanyTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  problem CodingProblem? @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([testId])
  @@map("company_test_problems")
}

// ============================================================
// Interview Models
// ============================================================

model InterviewSession {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  pathId          String?         @map("path_id")
  domain          String
  position        String
  round           InterviewRound  @default(general)
  language        String          @default("zh")
  difficulty      Int             @default(3)
  overallFeedback String?         @map("overall_feedback")
  score           Int?
  duration        Int?
  status          InterviewStatus @default(in_progress)
  startedAt       DateTime        @default(now()) @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("interview_sessions")
}

model InterviewQuestion {
  id         String    @id @default(uuid())
  sessionId  String    @map("session_id")
  order      Int
  question   String
  answer     String?
  evaluation String?
  score      Int?
  isCorrect  Boolean?  @map("is_correct")
  hints      String?
  difficulty Int?
  createdAt  DateTime  @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("interview_questions")
}

// ============================================================
// Resource Chunk & Bookmark Models
// ============================================================

model ResourceChunk {
  id         String   @id @default(uuid())
  resourceId String   @map("resource_id")
  content    String
  startTime  Int?     @map("start_time")
  endTime    Int?     @map("end_time")
  language   String?
  createdAt  DateTime @default(now()) @map("created_at")

  resource ResourceIndex @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, startTime])
  @@map("resource_chunks")
}

model UserBookmark {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String?  @map("resource_id")
  chunkId    String?  @map("chunk_id")
  questionId String?  @map("question_id")
  problemId  String?  @map("problem_id")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("user_bookmarks")
}
